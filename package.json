{
  "name": "minima.zig",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ts": "esbuild src/index.mts --bundle --format=esm --target=es2022 --outfile=dist/index.mjs",
    "build:wasm": "./build.sh",
    "build:all": "pnpm run build:wasm && pnpm run build:ts",
    "fmt": "zig fmt src && tsc -p tsconfig.json --noEmit",
    "dev:ts": "tsc -p tsconfig.json --watch",
    "dev:server": "go run main.go",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}